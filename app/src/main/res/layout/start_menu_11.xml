<?xml version="1.0" encoding="utf-8"?>
<!-- Windows 11 Start Menu -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/start_menu_content"
    android:layout_width="380dp"
    android:layout_height="520dp"
    android:clickable="true"
    android:background="@drawable/win11_start_menu_background"
    android:elevation="8dp"
    android:clipToOutline="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Search box at top -->
        <EditText
            android:id="@+id/search_box"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@drawable/win11_search_background"
            android:hint="Type here to search"
            android:textColor="@color/win11_text_primary"
            android:textColorHint="@color/win11_search_text"
            android:textSize="13sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:gravity="center_vertical"
            android:imeOptions="actionSearch"
            android:fontFamily="@font/segoeui_regular"
            android:layout_marginBottom="16dp" />

        <!-- Pinned section header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pinned"
                android:textColor="@color/win11_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/segoeui_bold"
                android:layout_alignParentStart="true" />

            <LinearLayout
                android:id="@+id/all_programs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/win11_taskbar_button_background"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/all_programs_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All apps"
                    android:textColor="@color/win11_text_primary"
                    android:textSize="12sp"
                    android:fontFamily="@font/segoeui_regular" />

                <ImageView
                    android:id="@+id/all_programs_arrow"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/start_menu_vista_arrow_right"
                    android:tint="@color/win11_text_primary" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Commands/Pinned items list -->
        <LinearLayout
            android:id="@+id/command_list_wrapper"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/welcome_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center|start"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/win11_start_menu_item_background">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/logo_vista" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome"
                    android:textColor="@color/win11_text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/segoeui_regular" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/windows_update_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center|start"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/win11_start_menu_item_background">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/update_available_vista" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Windows Update"
                    android:textColor="@color/win11_text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/segoeui_regular" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/commands_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <!-- All apps list (hidden by default) -->
        <LinearLayout
            android:id="@+id/app_list_wrapper"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/apps_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical"
                android:scrollbarStyle="outsideOverlay"
                android:scrollbarThumbVertical="@drawable/win11_scrollbar_thumb"
                android:scrollbarTrackVertical="@drawable/win11_scrollbar_track"
                android:scrollbarSize="6dp"
                android:fadeScrollbars="true" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/win11_divider"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Bottom bar: profile + power -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Profile -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <ImageView
                    android:id="@+id/profile_picture"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/user"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textColor="@color/win11_text_primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/segoeui_regular"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Right side: settings + power -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/settings_item"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:background="@drawable/win11_taskbar_button_background"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_run_scaled"
                        android:tint="@color/win11_text_primary" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/shutdown_button"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="7dp"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_run_scaled"
                    android:tint="@color/win11_text_primary"
                    android:background="@drawable/win11_taskbar_button_background"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>
