<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="44dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="10dp"
    android:layout_marginStart="2dp"
    android:layout_marginEnd="2dp"
    android:background="@drawable/win11_taskbar_button_background"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/taskbar_button_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/executable"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/taskbar_button_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Window"
        android:textColor="@color/win11_text_primary"
        android:textSize="12sp"
        android:fontFamily="@font/segoeui_regular"
        android:maxLines="1"
        android:maxWidth="120dp"
        android:ellipsize="end"
        android:layout_marginStart="6dp" />
</LinearLayout>
