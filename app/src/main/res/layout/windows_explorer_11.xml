<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/win11_surface">

    <!-- Toolbar area (navigation + breadcrumb) -->
    <LinearLayout
        android:id="@+id/explorer_toolbar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/win11_surface"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Back button -->
        <View
            android:id="@+id/back_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/win11_taskbar_button_background" />

        <!-- Forward button -->
        <View
            android:id="@+id/forward_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="2dp"
            android:background="@drawable/win11_taskbar_button_background" />

        <!-- Folder name / breadcrumb -->
        <TextView
            android:id="@+id/folder_name_small"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Folder Name"
            android:lines="1"
            android:fontFamily="@font/segoeui_regular"
            android:textColor="@color/win11_text_primary"
            android:textSize="12sp"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@drawable/win11_search_background"
            android:ellipsize="end" />

        <!-- Folder icon (small, next to breadcrumb) -->
        <ImageView
            android:id="@+id/folder_icon_small"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Content area (sidebar + files) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/explorer_toolbar"
        android:layout_above="@id/explorer_status_bar"
        android:orientation="horizontal">

        <!-- Sidebar -->
        <LinearLayout
            android:id="@+id/explorer_sidebar"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="@color/win11_explorer_sidebar"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">

            <!-- Quick access items (placeholder) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quick access"
                android:textColor="@color/win11_text_secondary"
                android:textSize="10sp"
                android:fontFamily="@font/segoeui_regular"
                android:layout_marginBottom="8dp" />
        </LinearLayout>

        <!-- File grid -->
        <GridView
            android:id="@+id/folder_icons_grid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:numColumns="auto_fit"
            android:verticalSpacing="0dp"
            android:horizontalSpacing="0dp"
            android:background="@color/win11_explorer_content"
            android:stretchMode="none"
            android:columnWidth="50dp"
            android:paddingEnd="20dp"
            android:scrollbars="vertical"
            android:scrollbarStyle="outsideOverlay"
            android:scrollbarAlwaysDrawVerticalTrack="true"
            android:scrollbarTrackVertical="@drawable/win11_scrollbar_track"
            android:scrollbarThumbVertical="@drawable/win11_scrollbar_thumb"
            android:scrollbarSize="6dp"
            android:scrollbarFadeDuration="300"
            android:fadeScrollbars="true" />
    </LinearLayout>

    <!-- Status bar -->
    <RelativeLayout
        android:id="@+id/explorer_status_bar"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_alignParentBottom="true"
        android:background="@color/win11_surface"
        android:paddingStart="8dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/explorer_number_of_items"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/segoeui_regular"
            android:textSize="11sp"
            android:textColor="@color/win11_text_secondary"
            android:text="12 items"
            android:layout_centerVertical="true" />

        <ImageView
            android:id="@+id/resize_drag_view"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:tint="@color/win11_text_disabled" />
    </RelativeLayout>
</RelativeLayout>
